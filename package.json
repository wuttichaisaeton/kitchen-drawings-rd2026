{
  "name": "kitchen-drawings-ui",
  "version": "1.0.0",
  "description": "Mobile/iPad web UI for Stainless Kitchen workshop drawing PDFs.",
  "scripts": {
    "start": "serve . -l tcp://0.0.0.0:${PORT:-3000} --no-clipboard --no-port-switching",
    "dev": "serve . -l 3000",
    "build:editor": "node editor/build.mjs",
    "watch:editor": "node editor/build.mjs --watch"
  },
  "dependencies": {
    "serve": "^14.2.0",
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
